{
  "name": "faah-terminal-sound",
  "displayName": "FAAH Terminal Sound",
  "description": "Plays FAAH sound when terminal errors occur",
  "version": "1.0.0",
  "publisher": "raghul-tech",
  "repository": {
    "type": "git",
    "url": "https://github.com/raghul-tech/faah-terminal-sound"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "faah-terminal.toggle",
        "title": "FAAH: Toggle Sound",
        "category": "FAAH"
      },
      {
        "command": "faah-terminal.testSound",
        "title": "FAAH: Test Sound",
        "category": "FAAH"
      }
    ],
    "configuration": {
      "title": "FAAH Terminal",
      "properties": {
        "faah-terminal.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable FAAH sound"
        },
        "faah-terminal.cooldown": {
          "type": "number",
          "default": 1000,
          "minimum": 100,
          "maximum": 10000,
          "description": "Cooldown between sounds in milliseconds"
        },
        "faah-terminal.monitorTerminal": {
          "type": "boolean",
          "default": true,
          "description": "Monitor terminal for errors"
        },
        "faah-terminal.errorPatterns": {
          "type": "array",
          "default": [
            "error",
            "failed",
            "fail",
            "fatal",
            "exception",
            "not found",
            "command not found",
            "permission denied",
            "syntax error",
            "undefined",
            "cannot",
            "unable to",
            "could not",
            "npm ERR!",
            "traceback",
            "Exception:",
            "SyntaxError",
            "TypeError",
            "ReferenceError"
          ],
          "description": "Patterns to detect errors in terminal output"
        },
        "faah-terminal.quietHours": {
          "type": "object",
          "default": {
            "enabled": false,
            "start": "22:00",
            "end": "08:00"
          },
          "description": "Quiet hours when sound is muted"
        }
      }
    },
    "keybindings": [
      {
        "command": "faah-terminal.toggle",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f",
        "when": "editorTextFocus"
      }
    ]
  },
  "enabledApiProposals": [
    "terminalDataWriteEvent"
  ],
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "build": "npm run package",
    "dev": "npm run watch",
    "clean": "rm -rf dist out node_modules"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^18.18.0",
    "@types/play-sound": "^1.1.2",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.0.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.0"
  },
  "icon": "media/icon.png",
  "keywords": [
    "terminal",
    "error",
    "sound",
    "audio",
    "alert",
    "notification",
    "faah",
    "beep"
  ],
  "dependencies": {
    "play-sound": "^1.1.6"
  }
}
