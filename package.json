{
  "name": "faah-terminal-alert",
  "displayName": "FAAH Terminal Alert",
  "description": "Plays a sound when terminal commands exit with an error. Useful for long builds, tests, and CI/CD workflows.",
  "version": "1.0.0",
  "publisher": "raghul-tech",
  "repository": {
    "type": "git",
    "url": "https://github.com/raghul-tech/faah-terminal-alert"
  },
  "homepage": "https://github.com/raghul-tech/faah-terminal-alert/blob/main/README.md",
  "bugs": {
    "url": "https://github.com/raghul-tech/faah-terminal-alert/issues"
  },
  "license": "MIT",
  "icon": "media/icon.png",
  "qna": "marketplace",
  "keywords": [
    "terminal",
    "error",
    "sound",
    "alert",
    "notification",
    "faah",
    "beep",
    "build",
    "ci",
    "productivity"
  ],
  "badges": [
    {
      "url": "https://img.shields.io/badge/platform-windows%20%7C%20macos%20%7C%20linux-blue",
      "href": "https://marketplace.visualstudio.com/items?itemName=raghul-tech.faah-terminal-alert",
      "description": "Supported Platforms"
    }
  ],
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "faah-terminal-alert.toggle",
        "title": "Toggle Sound",
        "category": "FAAH Terminal Alert"
      },
      {
        "command": "faah-terminal-alert.debug",
        "title": "Toggle Debug Logging",
        "category": "FAAH Terminal Alert"
      },
      {
        "command": "faah-terminal-alert.testSound",
        "title": "Test Sound",
        "category": "FAAH Terminal Alert"
      }
    ],
    "configuration": {
      "title": "FAAH Terminal Alert",
      "properties": {
        "faah-terminal-alert.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable FAAH sound"
        },
        "faah-terminal-alert.debugEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable/disable debug logging"
        },
        "faah-terminal-alert.cooldown": {
          "type": "number",
          "default": 1000,
          "minimum": 0,
          "description": "Minimum time in milliseconds between sounds (prevents spamming)"
        }
      }
    },
    "keybindings": [
      {
        "command": "faah-terminal-alert.toggle",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f"
      },
      {
        "command": "faah-terminal-alert.debug",
        "key": "ctrl+alt+d",
        "mac": "cmd+alt+d"
      },
      {
        "command": "faah-terminal-alert.testSound",
        "key": "ctrl+alt+t",
        "mac": "cmd+alt+t"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "package": "vsce package",
    "test": "node .vscode-test.mjs --verbose"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.22",
    "@types/vscode": "^1.74.0",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.4",
    "mocha": "^11.7.5",
    "typescript": "^5.3.3",
    "vsce": "^1.97.0"
  }
}