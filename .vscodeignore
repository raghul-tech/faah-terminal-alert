# Test folders
.vscode-test/**
test/**
**/*.test.js
**/*.test.ts

# Build artifacts
node_modules/**
!node_modules/vscode/**
dist/test/**

# Source files (already compiled)
src/**
!src/extension.ts
tsconfig.json
.eslintrc*
.eslintignore

# Git and GitHub
.git/**
.github/**
!.github/README.md
.gitignore
.gitattributes

# CI/CD workflows
.github/workflows/**
!.github/workflows/release.yml

# VS Code files
.vscode/**
!.vscode/launch.json
!.vscode/tasks.json

# Development files
*.vsix
.vscode-test.mjs
esbuild.js
mocha.*

# Documentation (keep only essential)
CHANGELOG.md
README.md
LICENSE.txt
PRIVACY.md
SUPPORT.md

# Media (keep only your icon and sound)
!media/icon.png
!media/faah.wav
media/**/*.psd
media/**/*.xcf

# Logs
*.log
npm-debug.log*